    padding: 4px 12px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--amber-light);
  }

  /* ── SESSION HEADER ── */
  .session-header {
    border-bottom: 1px solid var(--rule-bright);
    padding-bottom: 16px;
    margin: 48px 0 32px;
  }
  .session-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 6px;
    display: block;
  }
  .session-header h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    color: var(--white);
  }

  /* ── FRAMEWORK SECTION ── */
  .framework {
    margin-bottom: 48px;
    padding-left: 20px;
    border-left: 2px solid var(--rule);
  }
  .framework-number {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 4px;
    display: block;
  }
  .framework h4 {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    color: var(--amber-light);
    margin-bottom: 16px;
  }

  /* ── CONTENT BLOCKS ── */
  .block {
    margin-bottom: 24px;
  }
  .block-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 8px;
    display: block;
  }
  p {
    font-size: 0.95rem;
    color: var(--text-soft);
    margin-bottom: 12px;
    line-height: 1.8;
  }

  /* ── QUOTE BLOCK ── */
  .quote-block {
    background: rgba(212,160,23,0.05);
    border-left: 3px solid var(--amber);
    padding: 16px 20px;
    margin: 16px 0;
    font-family: 'Playfair Display', serif;
    font-style: italic;
