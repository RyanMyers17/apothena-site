    padding: 10px 14px;
    text-align: left;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--amber-light);
  }
  .ref-table td {
    border: 1px solid rgba(212,160,23,0.12);
    padding: 10px 14px;
    color: var(--text-soft);
    vertical-align: top;
    line-height: 1.65;
  }
  .ref-table tr:nth-child(even) td {
    background: rgba(255,255,255,0.02);
  }

  /* ── COACH NOTE ── */
  .coach-note {
    background: rgba(212,160,23,0.06);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--amber-light);
    padding: 16px 20px;
    margin: 20px 0;
    font-size: 0.88rem;
    color: var(--text-soft);
    line-height: 1.7;
  }
  .coach-note strong {
    color: var(--amber-light);
    font-weight: 700;
  }

  /* ── WATCH FOR ── */
  .watch-list {
    list-style: none;
    margin: 12px 0;
  }
  .watch-list li {
    font-size: 0.88rem;
    color: var(--text-soft);
    padding: 8px 0 8px 20px;
    border-bottom: 1px solid rgba(212,160,23,0.08);
    position: relative;
    line-height: 1.65;
  }
  .watch-list li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--amber);
    font-weight: 700;
  }
  .watch-list li:last-child { border-bottom: none; }

  /* ── ACTION ITEMS TABLE ── */
  .action-table {
    width: 100%;
    border-collapse: collapse;
    margin: 16px 0;
    font-size: 0.85rem;
  }
  .action-table th {
    background: rgba(212,160,23,0.08);
    border: 1px solid var(--rule);
    padding: 8px 14px;
    text-align: left;
    font-size: 0.62rem;
