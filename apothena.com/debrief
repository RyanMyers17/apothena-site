    text-align: center;
    color: var(--amber);
    font-weight: 700;
  }

  /* ── SYNTHESIS TABLE ── */
  .synthesis-table {
    width: 100%;
    border-collapse: collapse;
    margin: 16px 0;
    font-size: 0.85rem;
  }
  .synthesis-table th {
    background: rgba(212,160,23,0.08);
    border: 1px solid var(--rule);
    padding: 8px 14px;
    text-align: left;
    font-size: 0.62rem;
    font-weight: 700;
