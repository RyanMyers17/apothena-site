    font-size: 0.9rem;
    color: rgba(255,255,255,0.7);
    padding: 10px 0 10px 20px;
    border-bottom: 1px solid rgba(212,160,23,0.1);
    position: relative;
    line-height: 1.65;
  }
  .prompt-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--amber);
  }
  .prompt-list li:last-child { border-bottom: none; }

  /* ── REFERENCE TABLE ── */
  .ref-table {
    width: 100%;
    border-collapse: collapse;
    margin: 16px 0 24px;
    font-size: 0.85rem;
  }
