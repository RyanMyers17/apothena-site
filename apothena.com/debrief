  .footer-inner {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }
  .footer-brand {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
